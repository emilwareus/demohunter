      {
        "cacheKey": "6868db7bfc3fe509b672a925f4a859932e0643dea1d030b43929b00833348a29",
        "text": "DemoHunter turns Playwright style automation into narrated product demos you can regenerate locally.",
        "chapterTitle": "What it is",
        "startMs": 3,
        "endMs": 6173,
        "durationMs": 6170
      },
      {
        "cacheKey": "7cbb5b1e5a35a52d2fad4e359e9da4579f2a374820beca2a53d0910be220f775",
        "text": "Use it for docs, DevRel, release notes, and pull requests where the reviewer needs to see the flow, not just read about it.",
        "chapterTitle": "What it is",
        "startMs": 8817,
        "endMs": 17085,
        "durationMs": 8268
      },
      {
        "cacheKey": "5ee4c6ddf35e7a98505a719329d2170a6ef017e401833370740aabcaafcdd5d7",
        "text": "A demo is just a dot tour dot ts file: chapters, steps, Playwright locators, and narration around real UI motion.",
        "chapterTitle": "How it is written",
        "startMs": 20136,
        "endMs": 28931,
        "durationMs": 8795
      },
      {
        "cacheKey": "63944818b1dd6a7e290f836ed395f0119f6f12ff3a82a9186bfb0d474b8ebab5",
        "text": "Then run npx demohunter generate with the tour file. Always keep your documation videos up-to-date!",
